{
  "name": "@100xbot/agent-input",
  "version": "0.3.19",
  "description": "Reusable AI agent chat input bar with mentions, speech, file upload, and workflow review",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./recording": {
      "types": "./dist/recording.d.ts",
      "import": "./dist/recording.mjs",
      "require": "./dist/recording.cjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.mjs",
      "require": "./dist/workflow.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup && npx @tailwindcss/cli -i src/styles.build.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo:dev": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build",
    "test:e2e": "jest --config e2e/jest.config.cjs --runInBand"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/100x-bot/agent-input.git"
  },
  "keywords": [
    "react",
    "agent",
    "chat",
    "input",
    "mentions",
    "speech",
    "workflow"
  ],
  "dependencies": {
    "@tiptap/core": "^3.20.5",
    "@tiptap/extension-document": "^3.20.5",
    "@tiptap/extension-hard-break": "^3.20.5",
    "@tiptap/extension-history": "^3.20.5",
    "@tiptap/extension-mention": "^3.20.5",
    "@tiptap/extension-paragraph": "^3.20.5",
    "@tiptap/extension-text": "^3.20.5",
    "@tiptap/extensions": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/suggestion": "^3.20.5",
    "free-text-json-parser": "^0.0.1"
  }
}
