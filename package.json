{
  "name": "@100xbot/agent-input",
  "version": "0.2.0",
  "description": "Reusable AI agent chat input bar with mentions, speech, file upload, and workflow review",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./recording": {
      "types": "./dist/recording.d.ts",
      "import": "./dist/recording.mjs",
      "require": "./dist/recording.cjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.mjs",
      "require": "./dist/workflow.cjs"
    },
    "./styles": "./src/tailwind.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "demo:dev": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "lucide-react": ">=0.300",
    "framer-motion": ">=10"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.500.0",
    "framer-motion": "^12.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/100x-bot/agent-input.git"
  },
  "keywords": [
    "react",
    "agent",
    "chat",
    "input",
    "mentions",
    "speech",
    "workflow"
  ]
}
